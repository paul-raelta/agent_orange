# Agent Orange — workers/ environment.
# Copy to .env and fill in real values. .env is gitignored.

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Market data + news + insider ---
FINNHUB_API_KEY=...

# --- Email (Gmail SMTP with App Password) ---
# https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=................

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM=+1XXXXXXXXXX

# --- Single hardcoded user (until auth lands) ---
USER_EMAIL=you@example.com
USER_PHONE=+353XXXXXXXXX

# --- Optional overrides ---
# DATABASE_URL=sqlite+aiosqlite:///./var/ao.db
# API_PORT=8000
# AO_RUN_SCHEDULER_IN_PROCESS=0
# AO_SCHEDULER_MODE=inproc
# AO_LOG_LEVEL=INFO
